
generator client {
  provider = "prisma-client"
  output   = "../lib/generated/prisma"
}

datasource db {
  provider = "postgresql"
}



enum Role {
  USER
  LAWYER
  ADMIN
}

enum CaseStatus {
  OPEN
  IN_PROGRESS
  CLOSED
  DISMISSED
}

enum DocumentType {
  PDF
  DOCX
  TXT
}

enum ServiceType {
  LAWYER
  LEGAL_AID
  NGO
}



model User {
  id            String   @id @default(cuid())
  clerkId       String   @unique
  email         String   @unique
  name          String?
  role          Role     @default(USER)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  cases         Case[]
  documents     Document[]
  chatSessions  ChatSession[]
}



model ChatSession {
  id        String   @id @default(cuid())
  user      User     @relation(fields: [userId], references: [id])
  userId    String
  createdAt DateTime @default(now())

  messages  ChatMessage[]
}

model ChatMessage {
  id            String   @id @default(cuid())
  session       ChatSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  sessionId     String
  role          String   // "user" | "assistant"
  content       String
  createdAt     DateTime @default(now())
}



model Case {
  id            String      @id @default(cuid())
  title         String
  description   String?
  courtName     String?
  nextHearing   DateTime?
  status        CaseStatus  @default(OPEN)
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  user          User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId        String

  hearings      Hearing[]
  statusHistory StatusHistory[]
}

model Hearing {
  id        String   @id @default(cuid())
  date      DateTime
  notes     String?
  case      Case     @relation(fields: [caseId], references: [id], onDelete: Cascade)
  caseId    String
  createdAt DateTime @default(now())
}

model StatusHistory {
  id        String     @id @default(cuid())
  status    CaseStatus
  note      String?
  case      Case       @relation(fields: [caseId], references: [id], onDelete: Cascade)
  caseId    String
  createdAt DateTime   @default(now())
}


model Document {
  id              String       @id @default(cuid())
  title           String
  fileUrl         String
  type            DocumentType
  originalText    String?
  simplifiedText  String?
  createdAt       DateTime     @default(now())

  user            User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId          String
}



model LegalRightCategory {
  id        String       @id @default(cuid())
  name      String       @unique
  rights    LegalRight[]
}

model LegalRight {
  id          String   @id @default(cuid())
  title       String
  description String
  simplified  String
  category    LegalRightCategory @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  categoryId  String
}



model LegalServiceProvider {
  id          String      @id @default(cuid())
  name        String
  description String?
  specialization String?
  state       String
  city        String?
  contactEmail String?
  contactPhone String?
  website     String?
  type        ServiceType
  createdAt   DateTime @default(now())
}